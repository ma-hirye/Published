/****** Temporal Filter 2: Consecutive Frequency ******/
// Keeps vegetation only if it persists for a minimum of thres_FF = 5 consecutive years
// Early years of a persistent vegetation patch are removed, since there is no special protection at the beginning of the time series.
// Any pixel that is vegetation in 2023 or 2024 is kept, even if it has a persistance lower that  thres_FF

var years_FF = ee.List.sequence(1985, 2024);


