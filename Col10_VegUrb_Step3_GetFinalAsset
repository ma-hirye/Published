///****** Function to compute consecutive vegetation
var consecutiveFilter = function(yearIndex, state) {
  state = ee.List(state);
  var prevCount = ee.Image(state.get(0));
  var filteredList = ee.List(state.get(1));

  var img = ee.Image(colList.get(yearIndex));
  var year = ee.Number(img.get('year'));
  var isVeg = img.eq(1);

  ///Update consecutive count: if vegetation, add 1; else reset to 0
  var newCount = prevCount
    .where(isVeg, prevCount.add(1))
    .where(isVeg.not(), 0);

  ///Special rule for last years: if not enough years left, keep pixels that are vegetated
  var yearsLeft = ee.Number(years_FF.get(-1)).subtract(year).add(1);

  var keepMask = ee.Image(0)
    .where(newCount.gte(thres_FF), 1) // standard
    .where(ee.Image.constant(yearsLeft.lt(thres_FF)).and(isVeg), 1); // last years

  ///Apply mask and rename band
  var keep = img.updateMask(keepMask)
                .rename('classification')
                .set('year', year)
                .set('system:time_start', img.get('system:time_start'));

  filteredList = filteredList.add(keep);

  return ee.List([newCount, filteredList]);
  
};


